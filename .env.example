# ──────────────────────────────────────
# WAZZAL Environment Variables
# ──────────────────────────────────────

# Database
DATABASE_URL=postgresql://wazzal_user:wazzal_password@localhost:5432/wazzal_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Backend
BACKEND_PORT=4000
NODE_ENV=development

# Frontend
VITE_API_URL=http://localhost:4000/api

# PostgreSQL (Docker)
POSTGRES_USER=wazzal_user
POSTGRES_PASSWORD=wazzal_password
POSTGRES_DB=wazzal_db
