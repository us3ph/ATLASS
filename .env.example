# ──────────────────────────────────────
# ATLASS Environment Variables
# ──────────────────────────────────────
# SECRETS are NOT stored here — they go in ./secrets/ folder.
# See secrets/README.md for setup.
#
# Required secrets files:
#   secrets/openrouter_api_key   → Your OpenRouter (or OpenAI) API key
#   secrets/jwt_secret           → JWT signing secret (random 64-char hex)
#   secrets/db_password           → PostgreSQL password

# Database
DATABASE_URL=postgresql://atlass_user:<db_password>@localhost:5432/atlass_db

# Backend
BACKEND_PORT=4000
NODE_ENV=development

# AI Provider (swap baseURL + model to change providers)
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=nvidia/nemotron-nano-9b-v2:free
# For OpenAI: AI_BASE_URL=https://api.openai.com/v1  AI_MODEL=gpt-4o

# Frontend
VITE_API_URL=http://localhost:4000/api

# PostgreSQL (Docker)
POSTGRES_USER=atlass_user
POSTGRES_PASSWORD=<see secrets/db_password>
POSTGRES_DB=atlass_db
